    "@types/react-dom": "^19",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8",
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/akxr-design-system.git"
  },
